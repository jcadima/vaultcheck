#!/usr/bin/env php
<?php

declare(strict_types=1);

// Support running from source (composer install) or as a global phar
$autoloadPaths = [
    __DIR__ . '/../vendor/autoload.php',
    __DIR__ . '/../../../autoload.php', // global composer install
];

$autoloaded = false;
foreach ($autoloadPaths as $path) {
    if (file_exists($path)) {
        require $path;
        $autoloaded = true;
        break;
    }
}

if (!$autoloaded) {
    fwrite(STDERR, "Could not find autoloader. Run: composer install\n");
    exit(1);
}

use Symfony\Component\Console\Application;
use VaultCheck\Commands\AuditCommand;
use VaultCheck\Commands\DriftCommand;
use VaultCheck\Commands\FixCommand;
use VaultCheck\Commands\KeysCommand;
use VaultCheck\Commands\SnapshotCommand;

$app = new Application('VaultCheck', '1.0.0');
$app->add(new AuditCommand());
$app->add(new KeysCommand());
$app->add(new SnapshotCommand());
$app->add(new DriftCommand());
$app->add(new FixCommand());
$app->setDefaultCommand('audit', false);
$app->run();
